# READY IP Environment Variables
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Backend API (Railway)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BACKEND_API_SECRET=your-hmac-secret-here

# Authentication (NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Neo4j Aura
NEO4J_URI=bolt+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Patent data sources (server-side only, no NEXT_PUBLIC_ prefix)
IPSCREENER_API_KEY=your-ipscreener-key
GOOGLE_PATENTS_PROJECT_ID=your-gcp-project-id
